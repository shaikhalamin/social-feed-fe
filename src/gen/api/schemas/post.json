{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID identifier",
      "example": "123e4567-e89b-12d3-a456-426614174000"
    },
    "author": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "UUID identifier",
          "example": "123e4567-e89b-12d3-a456-426614174000"
        },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "avatarUrl": { "type": ["string", "null"], "format": "uri" }
      },
      "required": ["id", "firstName", "lastName", "avatarUrl"],
      "x-readme-ref-name": "AuthorSummary"
    },
    "content": { "type": "string" },
    "visibility": { "type": "string", "enum": ["public", "private"] },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "width": { "type": "integer", "exclusiveMinimum": 0 },
          "height": { "type": "integer", "exclusiveMinimum": 0 },
          "position": { "type": "integer", "minimum": 0 }
        },
        "required": ["url", "width", "height", "position"],
        "x-readme-ref-name": "PostImage"
      }
    },
    "counters": {
      "type": "object",
      "properties": {
        "likes": { "type": "integer", "minimum": 0 },
        "comments": { "type": "integer", "minimum": 0 }
      },
      "required": ["likes", "comments"],
      "x-readme-ref-name": "PostCounters"
    },
    "viewerState": {
      "type": "object",
      "properties": { "liked": { "type": "boolean" } },
      "required": ["liked"],
      "x-readme-ref-name": "ViewerLikeState"
    },
    "likesPreview": {
      "type": "object",
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "preview": {
          "type": "array",
          "items": {
