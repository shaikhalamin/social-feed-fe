      "required": ["count", "preview"],
      "x-readme-ref-name": "LikesPreview"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp",
      "example": "2026-05-10T10:30:00.000Z"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp",
      "example": "2026-05-10T10:30:00.000Z"
    }
