            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "description": "UUID identifier",
                "example": "123e4567-e89b-12d3-a456-426614174000"
              },
              "firstName": { "type": "string" },
              "lastName": { "type": "string" },
